# stub mode (default) — ローカル開発はこのまま使う
APP_MODE=stub
DATABASE_URL=file:./dev.db
SESSION_SECRET=dev-secret-change-me-32chars-long-please

# CMS source
# "local" (default) — gas/seed-data/*.tsv を読み込む。GAS 不要でローカル開発可能。
# "spreadsheet"     — GAS Webhook 経由で Google Spreadsheet を参照する。
# "sqlite"          — deprecated (local と同義)。起動時に warning ログを出力する。
CMS_SOURCE=local

# アップロードトークン署名用シークレット (C-2 対策)
# 未設定の場合は SESSION_SECRET を流用する。
# 本番環境では SESSION_SECRET と異なる値を設定することを推奨。
# UPLOAD_SIGNING_SECRET=

# prod mode (Phase 4) — Vercel Marketplace integration が auto-inject する
# 以下は手動で設定しないこと。Vercel ダッシュボードの integration から注入される。
#
# APP_MODE=prod
#
# --- Neon Postgres (Vercel Marketplace) ---
# DATABASE_URL=           # Neon が auto-inject
#
# --- Clerk (Vercel Marketplace) ---
# CLERK_SECRET_KEY=       # Clerk が auto-inject
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=  # Clerk が auto-inject
# CLERK_WEBHOOK_SECRET=   # Clerk dashboard > Webhooks で生成し手動設定
#
# --- Vercel Blob (Vercel Marketplace) ---
# BLOB_READ_WRITE_TOKEN=  # Vercel Blob が auto-inject
#
# --- Resend (Vercel Marketplace) ---
# RESEND_API_KEY=         # Resend が auto-inject
#
# --- Cron 認証 (手動設定) ---
# CRON_SECRET=            # Vercel env で手動設定。/api/cron/* エンドポイントの Bearer 認証に使用
