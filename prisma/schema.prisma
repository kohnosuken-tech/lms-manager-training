// LMS — Prisma schema
//
// Notes:
// - **Postgres** を本番 / 開発両方で採用 (Vercel Postgres / Neon)。
//   ローカルでも Postgres URL を使う。SQLite は Sprint #6 まで使っていたが Vercel 化で廃止。
// - 互換性のため Json 型は使用しない (文字列 + zod パース)。@db.* も付けない。
// - 主要な検索パスに合わせて複合インデックスを定義済み。
// - Phase E: Course / Lesson / Test / Question / Choice は CmsPort (TSV fixture / Spreadsheet / Notion) へ移行。
//   Enrollment / Progress / Submission / Answer の courseId / lessonId / testId / questionId /
//   choiceId は string FK として保持 (Prisma relation は不要)。

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------- Enums ----------

enum Role {
  STUDENT
  ADMIN
}

enum SubmissionStatus {
  IN_PROGRESS
  SUBMITTED
  PASSED
  FAILED
}

enum AuditAction {
  USER_LOGIN
  USER_CREATE
  USER_UPDATE
  USER_DEACTIVATE
  ROLE_CHANGE
  COURSE_CREATE
  COURSE_UPDATE
  COURSE_PUBLISH
  LESSON_CREATE
  LESSON_UPDATE
  LESSON_DELETE
  ENROLLMENT_CREATE
  ENROLLMENT_DELETE
  TEST_CREATE
  TEST_UPDATE
  TEST_PUBLISH
  SUBMISSION_GRADE
  EXPORT_CSV
}

// ---------- Core entities ----------

model User {
  id             String   @id @default(cuid())
  clerkUserId    String?  @unique // モックでは null 可、本番で Clerk と紐付け
  email          String   @unique
  name           String
  role           Role     @default(STUDENT)
  deactivated    Boolean  @default(false)
  sessionVersion Int      @default(1) // H-2: JWT revoke 用バージョン番号
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  enrollments  Enrollment[]
  progresses   Progress[]
  submissions  Submission[]
  auditLogs    AuditLog[]   @relation("AuditActor")

  @@index([role, deactivated])
}

model Enrollment {
  id          String    @id @default(cuid())
  userId      String
  courseId    String    // CmsPort の Course.id を string FK として保持
  assignedAt  DateTime  @default(now())
  dueAt       DateTime?
  completedAt DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
  @@index([userId, completedAt])
  @@index([courseId, completedAt])
  @@index([dueAt])
}

model Progress {
  id              String    @id @default(cuid())
  userId          String
  lessonId        String    // CmsPort の Lesson.id を string FK として保持
  watchedSec      Int       @default(0)   // 累計視聴秒
  lastPositionSec Int       @default(0)   // 最後の再生位置
  completed       Boolean   @default(false)
  completedAt     DateTime?
  updatedAt       DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
  @@index([userId, completed])
}

// ---------- Submission ----------

model Submission {
  id          String           @id @default(cuid())
  testId      String           // CmsPort の Test.id を string FK として保持
  userId      String
  status      SubmissionStatus @default(IN_PROGRESS)
  score       Int?             // 0-100
  attemptNo   Int              @default(1)
  startedAt   DateTime         @default(now())
  submittedAt DateTime?

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  answers Answer[]

  @@index([testId, userId])
  @@index([userId, status])
}

model Answer {
  id           String @id @default(cuid())
  submissionId String
  questionId   String // CmsPort の Question.id を string FK として保持
  choiceId     String // CmsPort の Choice.id を string FK として保持

  submission Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@unique([submissionId, questionId, choiceId])
  @@index([submissionId])
}

// ---------- Audit ----------

model AuditLog {
  id        String      @id @default(cuid())
  actorId   String?
  action    AuditAction
  target    String?     // 対象エンティティの参照 (例: "Course:abc123")
  diff      String      @default("") // JSON 文字列。zod でパースして利用
  at        DateTime    @default(now())
  prevHash  String?     // 直前のレコードの hash (最初のレコードは null)
  hash      String      @default("") // このレコード自体の SHA-256 hex

  actor User? @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([actorId, at])
  @@index([action, at])
}
