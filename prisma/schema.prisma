// LMS — Prisma schema
//
// Notes:
// - モックでは provider = "sqlite" を採用 (DATABASE_URL=file:./dev.db)。
//   本番切替時は provider を "postgresql" に変更し DATABASE_URL を Neon に向ける。
// - 互換性のため Json 型は使用しない (文字列 + zod パース)。@db.* も付けない。
// - 主要な検索パスに合わせて複合インデックスを定義済み。

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ---------- Enums ----------

enum Role {
  STUDENT
  ADMIN
}

enum QuestionType {
  SINGLE
  MULTIPLE
}

enum SubmissionStatus {
  IN_PROGRESS
  SUBMITTED
  PASSED
  FAILED
}

enum AuditAction {
  USER_LOGIN
  USER_CREATE
  USER_UPDATE
  USER_DEACTIVATE
  ROLE_CHANGE
  COURSE_CREATE
  COURSE_UPDATE
  COURSE_PUBLISH
  LESSON_CREATE
  LESSON_UPDATE
  LESSON_DELETE
  ENROLLMENT_CREATE
  ENROLLMENT_DELETE
  TEST_CREATE
  TEST_UPDATE
  TEST_PUBLISH
  SUBMISSION_GRADE
  EXPORT_CSV
}

// ---------- Core entities ----------

model User {
  id             String   @id @default(cuid())
  clerkUserId    String?  @unique // モックでは null 可、本番で Clerk と紐付け
  email          String   @unique
  name           String
  role           Role     @default(STUDENT)
  deactivated    Boolean  @default(false)
  sessionVersion Int      @default(1) // H-2: JWT revoke 用バージョン番号
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  enrollments  Enrollment[]
  progresses   Progress[]
  submissions  Submission[]
  auditLogs    AuditLog[]   @relation("AuditActor")

  @@index([role, deactivated])
}

model Course {
  id          String   @id @default(cuid())
  title       String
  description String
  order       Int      @default(0)
  published   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  lessons     Lesson[]
  enrollments Enrollment[]
  tests       Test[]

  @@index([published, order])
}

model Lesson {
  id                      String   @id @default(cuid())
  courseId                String
  title                   String
  description             String   @default("")
  videoUrl                String   // モックでは "/sample.mp4"、本番は Blob URL
  durationSec             Int      @default(0)
  order                   Int      @default(0)
  blockSeek               Boolean  @default(false) // 早送り抑止
  requiredCompletionRate  Float?   // null の場合はデフォルト 0.95
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  course      Course     @relation(fields: [courseId], references: [id], onDelete: Cascade)
  progresses  Progress[]

  @@index([courseId, order])
}

model Enrollment {
  id         String   @id @default(cuid())
  userId     String
  courseId   String
  assignedAt DateTime @default(now())
  dueAt      DateTime?
  completedAt DateTime?

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
  @@index([userId, completedAt])
  @@index([courseId, completedAt])
  @@index([dueAt])
}

model Progress {
  id              String   @id @default(cuid())
  userId          String
  lessonId        String
  watchedSec      Int      @default(0)   // 累計視聴秒
  lastPositionSec Int      @default(0)   // 最後の再生位置
  completed       Boolean  @default(false)
  completedAt     DateTime?
  updatedAt       DateTime @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
  @@index([userId, completed])
}

// ---------- Test / Submission ----------

model Test {
  id                  String   @id @default(cuid())
  courseId            String
  title               String
  description         String   @default("")
  prerequisiteCourseId String? // 受講条件 (このコース完了で受験可)
  passingScore        Int      @default(70) // 0-100
  maxAttempts         Int      @default(3)
  timeLimitSec        Int?     // 任意のタイムリミット (null = 無制限)
  shuffleQuestions    Boolean  @default(true)
  shuffleChoices      Boolean  @default(true)
  published           Boolean  @default(false)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  course      Course      @relation(fields: [courseId], references: [id], onDelete: Cascade)
  questions   Question[]
  submissions Submission[]

  @@index([courseId, published])
}

model Question {
  id          String       @id @default(cuid())
  testId      String
  type        QuestionType @default(SINGLE)
  prompt      String
  explanation String       @default("") // 提出後に表示する解説
  order       Int          @default(0)

  test    Test     @relation(fields: [testId], references: [id], onDelete: Cascade)
  choices Choice[]
  answers Answer[]

  @@index([testId, order])
}

model Choice {
  id         String  @id @default(cuid())
  questionId String
  label      String
  correct    Boolean @default(false)
  order      Int     @default(0)

  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  answers  Answer[]

  @@index([questionId, order])
}

model Submission {
  id          String           @id @default(cuid())
  testId      String
  userId      String
  status      SubmissionStatus @default(IN_PROGRESS)
  score       Int?             // 0-100
  attemptNo   Int              @default(1)
  startedAt   DateTime         @default(now())
  submittedAt DateTime?

  test    Test    @relation(fields: [testId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  answers Answer[]

  @@index([testId, userId])
  @@index([userId, status])
}

model Answer {
  id           String  @id @default(cuid())
  submissionId String
  questionId   String
  choiceId     String  // 単一行 = 1 つの選択。複数選択時は Answer を複数行作る

  submission Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  question   Question   @relation(fields: [questionId], references: [id], onDelete: Cascade)
  choice     Choice     @relation(fields: [choiceId], references: [id], onDelete: Cascade)

  @@unique([submissionId, questionId, choiceId])
  @@index([submissionId])
}

// ---------- Audit ----------

model AuditLog {
  id        String      @id @default(cuid())
  actorId   String?
  action    AuditAction
  target    String?     // 対象エンティティの参照 (例: "Course:abc123")
  diff      String      @default("") // JSON 文字列。zod でパースして利用
  at        DateTime    @default(now())

  actor User? @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([actorId, at])
  @@index([action, at])
}
